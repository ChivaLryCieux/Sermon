<mah:MetroWindow x:Class="Sermon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:mdi="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        mc:Ignorable="d"
        Title="Sermon - Markdown编辑器" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <mah:MetroWindow.Resources>
        <SolidColorBrush x:Key="SwissBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="SwissSurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SwissTextBrush" Color="#111111"/>
        <SolidColorBrush x:Key="SwissMutedTextBrush" Color="#666666"/>
        <SolidColorBrush x:Key="SwissLineBrush" Color="#D8D8D8"/>
        <SolidColorBrush x:Key="SwissAccentBrush" Color="#E0001B"/>
        <SolidColorBrush x:Key="SwissHoverBrush" Color="#ECECEC"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource SwissSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style TargetType="ToolBarTray">
            <Setter Property="Background" Value="{StaticResource SwissSurfaceBrush}"/>
        </Style>

        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="{StaticResource SwissSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,1"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SwissHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource SwissTextBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource SwissSurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SwissHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource SwissTextBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource SwissSurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SwissTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SwissSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource SwissSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource SwissSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Background="{StaticResource SwissBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0">
            <MenuItem Header="_文件(F)">
                <MenuItem Header="_新建" Click="NewFileMenuItem_Click" InputGestureText="Ctrl+N">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="FileDocumentOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_打开文件..." Click="OpenFileMenuItem_Click" InputGestureText="Ctrl+O">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="FolderOpenOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_打开文件夹..." Click="OpenFolderMenuItem_Click" InputGestureText="Ctrl+Shift+O">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="FolderOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_保存" Click="SaveMenuItem_Click" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="ContentSave" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_另存为..." Click="SaveAsMenuItem_Click" InputGestureText="Ctrl+Shift+S">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="ContentSaveAll" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_退出" Click="ExitMenuItem_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_编辑(E)">
                <MenuItem Header="_查找" Click="FindMenuItem_Click" InputGestureText="Ctrl+F">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="Magnify" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_替换" Click="ReplaceMenuItem_Click" InputGestureText="Ctrl+H">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="FindReplace" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_视图(V)">
                <MenuItem Header="_编辑模式" Click="EditModeMenuItem_Click" IsCheckable="True" IsChecked="True">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="FileDocumentEditOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_预览模式" Click="PreviewModeMenuItem_Click" IsCheckable="True">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="Eye" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_分屏模式" Click="SplitModeMenuItem_Click" IsCheckable="True">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="ViewSplitVertical" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_明亮主题" Click="LightThemeMenuItem_Click" IsCheckable="True" IsChecked="True">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="WeatherSunny" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_暗黑主题" Click="DarkThemeMenuItem_Click" IsCheckable="True">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="WeatherNight" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_工具(T)">
                <MenuItem Header="_设置" Click="SettingsMenuItem_Click">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="Cog" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_帮助(H)">
                <MenuItem Header="_关于" Click="AboutMenuItem_Click">
                    <MenuItem.Icon>
                        <mdi:PackIconMaterial Kind="Information" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- 工具栏 -->
        <ToolBarTray Grid.Row="1">
            <ToolBar Band="1" BandIndex="1">
                <!-- 文件操作 -->
                <Button Click="NewFileMenuItem_Click" ToolTip="新建 (Ctrl+N)">
                    <mdi:PackIconMaterial Kind="FileDocumentOutline" Width="16" Height="16"/>
                </Button>
                <Button Click="OpenFileMenuItem_Click" ToolTip="打开文件 (Ctrl+O)">
                    <mdi:PackIconMaterial Kind="FolderOpenOutline" Width="16" Height="16"/>
                </Button>
                <Button Click="SaveMenuItem_Click" ToolTip="保存 (Ctrl+S)">
                    <mdi:PackIconMaterial Kind="ContentSave" Width="16" Height="16"/>
                </Button>
                <Separator/>
                
                <!-- 格式化工具 -->
                <Button Click="BoldButton_Click" ToolTip="加粗 (Ctrl+B)">
                    <mdi:PackIconMaterial Kind="FormatBold" Width="16" Height="16"/>
                </Button>
                <Button Click="ItalicButton_Click" ToolTip="斜体 (Ctrl+I)">
                    <mdi:PackIconMaterial Kind="FormatItalic" Width="16" Height="16"/>
                </Button>
                <Button Click="StrikethroughButton_Click" ToolTip="删除线">
                    <mdi:PackIconMaterial Kind="FormatStrikethrough" Width="16" Height="16"/>
                </Button>
                <Separator/>
                
                <!-- 标题工具 -->
                <ComboBox x:Name="HeadingComboBox" Width="100" SelectionChanged="HeadingComboBox_SelectionChanged" ToolTip="标题级别">
                    <ComboBoxItem Content="普通文本" Tag=""/>
                    <ComboBoxItem Content="标题 1" Tag="# "/>
                    <ComboBoxItem Content="标题 2" Tag="## "/>
                    <ComboBoxItem Content="标题 3" Tag="### "/>
                    <ComboBoxItem Content="标题 4" Tag="#### "/>
                    <ComboBoxItem Content="标题 5" Tag="##### "/>
                    <ComboBoxItem Content="标题 6" Tag="###### "/>
                </ComboBox>
                <Separator/>
                
                <!-- 列表和链接 -->
                <Button Click="BulletListButton_Click" ToolTip="无序列表">
                    <mdi:PackIconMaterial Kind="FormatListBulleted" Width="16" Height="16"/>
                </Button>
                <Button Click="NumberedListButton_Click" ToolTip="有序列表">
                    <mdi:PackIconMaterial Kind="FormatListNumbered" Width="16" Height="16"/>
                </Button>
                <Button Click="LinkButton_Click" ToolTip="插入链接">
                    <mdi:PackIconMaterial Kind="Link" Width="16" Height="16"/>
                </Button>
                <Button Click="ImageButton_Click" ToolTip="插入图片">
                    <mdi:PackIconMaterial Kind="Image" Width="16" Height="16"/>
                </Button>
                <Button Click="CodeBlockButton_Click" ToolTip="代码块">
                    <mdi:PackIconMaterial Kind="CodeBraces" Width="16" Height="16"/>
                </Button>
                <Button Click="TableButton_Click" ToolTip="插入表格">
                    <mdi:PackIconMaterial Kind="Table" Width="16" Height="16"/>
                </Button>
                <Separator/>
                
                <!-- 视图模式 -->
                <ToggleButton x:Name="EditModeToggle" IsChecked="True" Click="EditModeToggle_Click" ToolTip="编辑模式">
                    <mdi:PackIconMaterial Kind="FileDocumentEditOutline" Width="16" Height="16"/>
                </ToggleButton>
                <ToggleButton x:Name="PreviewModeToggle" Click="PreviewModeToggle_Click" ToolTip="预览模式">
                    <mdi:PackIconMaterial Kind="Eye" Width="16" Height="16"/>
                </ToggleButton>
                <ToggleButton x:Name="SplitModeToggle" Click="SplitModeToggle_Click" ToolTip="分屏模式">
                    <mdi:PackIconMaterial Kind="ViewSplitVertical" Width="16" Height="16"/>
                </ToggleButton>
            </ToolBar>
        </ToolBarTray>

        <!-- 主要内容区域 -->
        <Grid Grid.Row="2" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 文件资源管理器 -->
            <Border Grid.Column="0"
                    Background="{StaticResource SwissSurfaceBrush}"
                    BorderBrush="{StaticResource SwissLineBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="14,12">
                        <Rectangle Width="4"
                                   Height="18"
                                   Fill="{StaticResource SwissAccentBrush}"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="文件资源管理器"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Border Grid.Row="1" Background="{StaticResource SwissLineBrush}"/>
                    <TreeView x:Name="FileTreeView"
                              Grid.Row="2"
                              Margin="12"
                              SelectedItemChanged="FileTreeView_SelectedItemChanged"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource SwissLineBrush}"/>

            <!-- 编辑器区域 -->
            <mah:MetroTabControl x:Name="EditorTabControl" Grid.Column="2" 
                                 Margin="18,0,0,0"
                                 SelectionChanged="EditorTabControl_SelectionChanged"
                                 Background="{StaticResource SwissSurfaceBrush}"
                                 BorderBrush="{StaticResource SwissLineBrush}"
                                 BorderThickness="1">
            </mah:MetroTabControl>
        </Grid>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <mdi:PackIconMaterial Kind="FileDocumentOutline" Width="14" Height="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="WordCountTextBlock" Text="字数: 0  字符: 0"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <mdi:PackIconMaterial Kind="CursorText" Width="14" Height="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="CursorPositionTextBlock" Text="行: 1, 列: 1"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <mdi:PackIconMaterial Kind="CheckCircle" Width="14" Height="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusTextBlock" Text="准备就绪"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
