<Window x:Class="Sermon.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sermon"
        Width="1400"
        Height="900"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        FontFamily="Inter, Segoe UI, Noto Sans CJK SC"
        Background="#F7F7F4">

  <Window.Resources>
    <SolidColorBrush x:Key="SwissBackgroundBrush" Color="#F7F7F4" />
    <SolidColorBrush x:Key="SwissSurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SwissPanelBrush" Color="#FAFAF8" />
    <SolidColorBrush x:Key="SwissTextBrush" Color="#111111" />
    <SolidColorBrush x:Key="SwissMutedTextBrush" Color="#6A6A64" />
    <SolidColorBrush x:Key="SwissLineBrush" Color="#DCDCD6" />
    <SolidColorBrush x:Key="SwissAccentBrush" Color="#E30613" />
    <SolidColorBrush x:Key="SwissHoverBrush" Color="#EEEEEA" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Menu">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{StaticResource SwissHoverBrush}" />
    </Style>
    <Style Selector="Button.icon">
      <Setter Property="Width" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource SwissTextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissTextBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="{StaticResource SwissAccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissAccentBrush}" />
    </Style>
    <Style Selector="ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource SwissTextBrush}" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="ToggleButton:pointerover">
      <Setter Property="Background" Value="{StaticResource SwissHoverBrush}" />
    </Style>
    <Style Selector="ToggleButton:checked">
      <Setter Property="Background" Value="{StaticResource SwissTextBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissTextBrush}" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource SwissLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TreeView, ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TabControl">
      <Setter Property="Background" Value="White" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="10,7" />
    </Style>
  </Window.Styles>

  <Grid Background="{StaticResource SwissBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Menu Grid.Row="0" Background="{StaticResource SwissSurfaceBrush}" Padding="12,0">
      <MenuItem Header="_文件(F)">
        <MenuItem Header="_新建" Click="NewFileMenuItem_Click" HotKey="Ctrl+N" />
        <MenuItem Header="_打开文件..." Click="OpenFileMenuItem_Click" HotKey="Ctrl+O" />
        <MenuItem Header="_打开文件夹..." Click="OpenFolderMenuItem_Click" HotKey="Ctrl+Shift+O" />
        <Separator />
        <MenuItem Header="_保存" Click="SaveMenuItem_Click" HotKey="Ctrl+S" />
        <MenuItem Header="_另存为..." Click="SaveAsMenuItem_Click" HotKey="Ctrl+Shift+S" />
        <Separator />
        <MenuItem Header="_退出" Click="ExitMenuItem_Click" />
      </MenuItem>
      <MenuItem Header="_编辑(E)">
        <MenuItem Header="_查找" Click="FindMenuItem_Click" HotKey="Ctrl+F" />
        <MenuItem Header="_替换" Click="ReplaceMenuItem_Click" HotKey="Ctrl+H" />
        <Separator />
        <MenuItem Header="_插入链接" Click="LinkButton_Click" />
        <MenuItem Header="_插入图片" Click="ImageButton_Click" />
        <MenuItem Header="_插入代码块" Click="CodeBlockButton_Click" />
        <MenuItem Header="_插入表格" Click="TableButton_Click" />
      </MenuItem>
      <MenuItem Header="_视图(V)">
        <MenuItem Header="_编辑模式" Click="EditModeMenuItem_Click" />
        <MenuItem Header="_预览模式" Click="PreviewModeMenuItem_Click" />
        <MenuItem Header="_分屏模式" Click="SplitModeMenuItem_Click" />
        <Separator />
        <MenuItem Header="_AI记忆面板" Click="ToggleMemoryPanelMenuItem_Click" />
        <Separator />
        <MenuItem Header="_明亮主题" Click="LightThemeMenuItem_Click" />
        <MenuItem Header="_暗黑主题" Click="DarkThemeMenuItem_Click" />
      </MenuItem>
      <MenuItem Header="_工具(T)">
        <MenuItem Header="_设置" Click="SettingsMenuItem_Click" />
      </MenuItem>
      <MenuItem Header="_帮助(H)">
        <MenuItem Header="_关于" Click="AboutMenuItem_Click" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Background="{StaticResource SwissSurfaceBrush}"
            BorderBrush="{StaticResource SwissLineBrush}"
            BorderThickness="0,1,0,1"
            Padding="18,10">
      <Grid ColumnDefinitions="Auto,18,Auto,18,*,Auto" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="5" Height="24" Background="{StaticResource SwissAccentBrush}" />
          <StackPanel Spacing="0">
            <TextBlock Text="Sermon"
                       FontSize="18"
                       FontWeight="Bold"
                       LetterSpacing="0"
                       Foreground="{StaticResource SwissTextBrush}" />
            <TextBlock Text="Markdown Editor"
                       Margin="1,-2,0,0"
                       FontSize="10"
                       Foreground="{StaticResource SwissMutedTextBrush}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
          <Button Classes="icon"
                  Content="+"
                  Click="NewFileMenuItem_Click"
                  ToolTip.Tip="新建 Ctrl+N" />
          <Button Classes="icon"
                  Content="O"
                  Click="OpenFileMenuItem_Click"
                  ToolTip.Tip="打开 Ctrl+O" />
          <Button Classes="icon primary"
                  Content="S"
                  Click="SaveMenuItem_Click"
                  ToolTip.Tip="保存 Ctrl+S" />
        </StackPanel>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Button Classes="icon"
                  Content="B"
                  FontWeight="Bold"
                  Click="BoldButton_Click"
                  ToolTip.Tip="加粗 Ctrl+B" />
          <Button Classes="icon"
                  Content="I"
                  FontStyle="Italic"
                  Click="ItalicButton_Click"
                  ToolTip.Tip="斜体 Ctrl+I" />
          <Button Classes="icon"
                  Click="StrikethroughButton_Click"
                  ToolTip.Tip="删除线">
            <TextBlock Text="S" TextDecorations="Strikethrough" />
          </Button>
          <ComboBox x:Name="HeadingComboBox"
                    Width="104"
                    SelectionChanged="HeadingComboBox_SelectionChanged">
            <ComboBoxItem Content="正文" Tag="" />
            <ComboBoxItem Content="标题 1" Tag="# " />
            <ComboBoxItem Content="标题 2" Tag="## " />
            <ComboBoxItem Content="标题 3" Tag="### " />
            <ComboBoxItem Content="标题 4" Tag="#### " />
            <ComboBoxItem Content="标题 5" Tag="##### " />
            <ComboBoxItem Content="标题 6" Tag="###### " />
          </ComboBox>
          <Button Classes="icon"
                  Content="•"
                  Click="BulletListButton_Click"
                  ToolTip.Tip="项目列表" />
          <Button Classes="icon"
                  Content="1."
                  Click="NumberedListButton_Click"
                  ToolTip.Tip="编号列表" />
          <Button Classes="icon"
                  Content="[]"
                  Click="LinkButton_Click"
                  ToolTip.Tip="链接" />
          <Button Classes="icon"
                  Content="{}"
                  Click="CodeBlockButton_Click"
                  ToolTip.Tip="代码块" />
        </StackPanel>

        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="0" HorizontalAlignment="Right">
          <ToggleButton x:Name="EditModeToggle" Content="编辑" IsChecked="True" Click="EditModeToggle_Click" />
          <ToggleButton x:Name="PreviewModeToggle" Content="预览" Click="PreviewModeToggle_Click" />
          <ToggleButton x:Name="SplitModeToggle" Content="分屏" Click="SplitModeToggle_Click" />
          <ToggleButton x:Name="MemoryPanelToggle"
                        Content="记忆"
                        IsChecked="False"
                        Margin="8,0,0,0"
                        Click="MemoryPanelToggle_Click" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="MainContentGrid" Grid.Row="2" Margin="18,18,18,14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="244" MinWidth="180" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="320" MinWidth="280" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{StaticResource SwissPanelBrush}"
              BorderBrush="{StaticResource SwissLineBrush}"
              BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0" Margin="14,14,14,12">
            <TextBlock Text="文件资源管理器"
                       FontSize="12"
                       FontWeight="Bold"
                       LetterSpacing="0"
                       Foreground="{StaticResource SwissMutedTextBrush}"
                       VerticalAlignment="Center" />
          </DockPanel>
          <Border Grid.Row="1" Background="{StaticResource SwissLineBrush}" />
          <TreeView x:Name="FileTreeView"
                    Grid.Row="2"
                    Margin="12"
                    SelectionChanged="FileTreeView_SelectionChanged" />
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="1"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource SwissLineBrush}" />

      <TabControl x:Name="EditorTabControl"
                  Grid.Column="2"
                  Margin="16,0,0,0"
                  SelectionChanged="EditorTabControl_SelectionChanged"
                  Background="{StaticResource SwissSurfaceBrush}"
                  BorderBrush="{StaticResource SwissLineBrush}"
                  BorderThickness="1" />

      <GridSplitter x:Name="MemoryPanelSplitter"
                    Grid.Column="3"
                    Width="1"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource SwissLineBrush}" />

      <Border x:Name="MemoryPanelBorder"
              Grid.Column="4"
              Margin="16,0,0,0"
              Background="{StaticResource SwissPanelBrush}"
              BorderBrush="{StaticResource SwissLineBrush}"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,1,Auto,Auto,Auto,*">
          <DockPanel Grid.Row="0" Margin="14,14,14,12">
            <TextBlock Text="AI 记忆管理"
                       FontSize="12"
                       FontWeight="Bold"
                       LetterSpacing="0"
                       Foreground="{StaticResource SwissMutedTextBrush}"
                       VerticalAlignment="Center" />
          </DockPanel>
          <Border Grid.Row="1" Background="{StaticResource SwissLineBrush}" />
          <TextBlock x:Name="MemoryStatsTextBlock"
                     Grid.Row="2"
                     Margin="14,10,14,6"
                     Foreground="{StaticResource SwissMutedTextBrush}"
                     Text="记忆: 0 条  热门标签: -" />
          <TextBox x:Name="MemorySearchTextBox"
                   Grid.Row="3"
                   Margin="14,0,14,8"
                   Watermark="检索记忆（关键词）"
                   TextChanged="MemorySearchTextBox_TextChanged" />
          <TextBox x:Name="MemoryIntentTextBox"
                   Grid.Row="4"
                   Margin="14,0,14,8"
                   Watermark="输入当前任务意图（用于生成上下文包）" />
          <Grid Grid.Row="5" Margin="14,0,14,14" RowDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <Button Content="提取" Click="ExtractMemoryButton_Click" ToolTip.Tip="提取当前文档记忆" />
              <Button Content="上下文" Click="GenerateContextPackButton_Click" ToolTip.Tip="生成上下文包" />
              <Button Content="删除" Click="DeleteSelectedMemoryButton_Click" ToolTip.Tip="删除选中记忆" />
            </StackPanel>
            <ListBox x:Name="MemoryListBox"
                     Grid.Row="1"
                     Margin="0,10,0,0" />
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Background="{StaticResource SwissSurfaceBrush}"
            BorderBrush="{StaticResource SwissLineBrush}"
            BorderThickness="0,1,0,0"
            Padding="18,7">
      <Grid ColumnDefinitions="Auto,Auto,*">
        <TextBlock x:Name="WordCountTextBlock" FontSize="12" Foreground="{StaticResource SwissMutedTextBrush}" Text="字数: 0  字符: 0" />
        <TextBlock x:Name="CursorPositionTextBlock" Grid.Column="1" Margin="24,0,0,0" FontSize="12" Foreground="{StaticResource SwissMutedTextBrush}" Text="行: 1, 列: 1" />
        <TextBlock x:Name="StatusTextBlock" Grid.Column="2" HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource SwissMutedTextBrush}" Text="准备就绪" />
      </Grid>
    </Border>
  </Grid>
</Window>
